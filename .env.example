DATABASE_URL='postgresql://postgres:postgres@localhost:5432/personal_system?schema=public'
POSTGRES_DB='personal_system'
POSTGRES_USER='postgres'
POSTGRES_PASSWORD='postgres'
REDIS_URL='redis://localhost:6379'
SESSION_COOKIE_NAME='ps_session'
SESSION_TTL_SECONDS='604800'
# AI（可选）：未配置 OPENAI_API_KEY 时，聊天/上传会向量化接口会返回 503
OPENAI_API_KEY=''
# OPENAI_BASE_URL='https://api.openai.com/v1'
# 若兼容网关（如 LiteLLM）未登记 embeddings 用 Key，可单独指向官方或其它网关：
# OPENAI_EMBEDDING_API_KEY=''
# OPENAI_EMBEDDING_BASE_URL='https://api.openai.com/v1'
AI_CHAT_ENABLED='true'
AI_EMBEDDING_MODEL='text-embedding-3-small'
# 本地开发：知识文件落盘目录（需存在且可写；Docker 见 compose 挂载）
KNOWLEDGE_UPLOAD_DIR='./data/knowledge'
# 可选：完全覆盖内置默认可选模型（须为非空 JSON 数组；[] 或无效 JSON 会回退到内置列表）
# 内置默认含：openai-gpt-4o-mini、openai-gpt-4o、openai-gpt-4-turbo、openai-gpt-3.5-turbo（见 model-registry.ts）
# AI_CHAT_MODELS_JSON='[{"id":"openai-gpt-4o-mini","label":"GPT-4o mini","sdkModel":"gpt-4o-mini","capabilities":{"tools":true}}]'

